# ─────────────────────────────────────────────────────────────────────────────
# Yakkai Neri Backend — .env Template
# Copy this file to .env and fill in your values.
#
# LOCAL DEV:    APP_URL = http://localhost/yakkai-main/backend
# GODADDY PROD: APP_URL = https://yourdomain.com/backend
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# GoDaddy: get these from cPanel → MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# ── Auth ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate one at: https://generate-secret.vercel.app/64
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_64_CHARS
JWT_EXPIRY=86400

# ── App ───────────────────────────────────────────────────────────────────────
# Controls: base-path stripping in index.php + CORS allowed origin
APP_ENV=production
APP_URL=https://yourdomain.com/backend
