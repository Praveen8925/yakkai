Options -Indexes

# ── Protect sensitive files from public access ──────────────────────────────
<FilesMatch "^\.env|composer\.(json|lock)|\.git">
    Require all denied
</FilesMatch>

# ── Route all API requests through index.php ─────────────────────────────────
RewriteEngine On

# Pass Authorization header to PHP (Apache strips it by default)
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Works for both local dev (/yakkai-main/backend/) and production (/backend/).

# Skip real files and directories — serve them directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything else to index.php
RewriteRule ^(.*)$ index.php [QSA,L]
